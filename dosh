#!/usr/bin/env bash
# Do - The Simplest Build Tool on Earth.
# Documentation and examples see https://github.com/8gears/do
#
SCRIPTNAME=`basename "$0"`
BASEDIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
cd ${BASEDIR}

set -e

UPSTREAM_REPOS=(
    "node_exporter|https://github.com/prometheus/node_exporter.git|github.com/prometheus/node_exporter"
    "process-exporter|https://github.com/ncabatoff/process-exporter.git|github.com/ncabatoff/process-exporter"
)

setup() {
    mkdir -p upstream
    for entry in "${UPSTREAM_REPOS[@]}"; do
        IFS='|' read -r name url module <<< "$entry"
        if [ ! -d "upstream/$name" ]; then
            echo "Cloning $name..."
            git clone "$url" "upstream/$name"
        else
            echo "$name already present"
        fi
    done
}

update() {
    for entry in "${UPSTREAM_REPOS[@]}"; do
        IFS='|' read -r name url module <<< "$entry"
        echo "Checking $name..."
        git -C "upstream/$name" fetch --tags -q

        pinned=$(go list -m "$module" 2>/dev/null | awk '{print $2}')
        latest=$(git -C "upstream/$name" tag --sort=-v:refname | grep '^v' | head -1)

        if [ -z "$latest" ]; then
            echo "  $name: no tags found upstream"
        elif [ "$pinned" = "$latest" ]; then
            echo "  $name: up to date ($pinned)"
        else
            echo "  $name: pinned=$pinned  latest=$latest"
            echo "    -> go get ${module}@latest && go mod tidy && go build ./..."
        fi
    done
}

build() {
    go build -o node-process-agent .
}

install() {
    go build -o /usr/bin/node-process-agent .
    echo "Installed to /usr/bin/node-process-agent"
}

_sign_deb() {
    local deb="$1" keyid="$2"
    if ! /usr/share/debdelta/dpkg-sig -k "$keyid" --sign builder "$deb"; then
        echo "Error: signing failed" >&2
        exit 1
    fi
    echo "Signed: $deb"
}

deb() {
    build
    mkdir -p dist
    VERSION=$(cat VERSION) nfpm package --packager deb --target dist/
    local pkg
    pkg=$(ls -t dist/*.deb | head -1)
    if [ -n "${REPO_GPG_KEY:-}" ]; then
        _sign_deb "$pkg" "$REPO_GPG_KEY"
    else
        echo "Warning: REPO_GPG_KEY not set, package will not be signed"
    fi
    echo "Package written to dist/"
}

"$@" # <- execute the task
[ "$#" -gt 0 ] || printf "Usage:\n\t./${SCRIPTNAME} %s\n" "($(compgen -A function | grep '^[^_]' | paste -sd '|' -))"
